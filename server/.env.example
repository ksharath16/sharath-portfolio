# Port the Express server runs on
PORT=4000

# Where contact form submissions get delivered
CONTACT_TO_EMAIL=youremail@example.com

# SMTP credentials used to SEND the email (e.g. a Gmail app password,
# or a transactional email provider like Resend / SendGrid / Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@example.com
SMTP_PASS=your-app-password-here

# Comma-separated list of origins allowed to call this API in production
# e.g. https://sharath.dev,https://www.sharath.dev
ALLOWED_ORIGINS=http://localhost:5173
